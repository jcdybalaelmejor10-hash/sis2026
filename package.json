    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "sweetalert2": "^11.26.20"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9",
